# Telegram bot — from @BotFather
BOT_TOKEN=

# Personal Telegram chat_id of the bot owner — used as the destination for
# private status replies (response_poller in recommendations_bot.py).
USER_CHAT_ID=

# The single chat where the bot is allowed to operate. Inbound messages
# from any other chat (DMs, other groups) are silently ignored — the bot
# does not log them and does not reply.
# For a group chat this is a negative number, e.g. -1002237202930.
ALLOWED_CHAT_ID=
